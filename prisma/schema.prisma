generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          String    @default("user") // admin, user
  isActive      Boolean   @default(true)
  subscriptionEnd DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  projects      Project[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  il          String   @default("")
  ilce        String   @default("")
  semt        String   @default("")
  mahalle     String   @default("")
  pafta       String   @default("")
  ada         String   @default("")
  parsel      String   @default("")
  yuzolcum    Float    @default(0)
  fontSize    Int      @default(8)
  orientation String   @default("Dikey")
  paperSize   String   @default("A3")
  fitToPage   Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  owners      Owner[]
  attorneys   Attorney[]
  sections    Section[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Owner {
  id           String   @id @default(cuid())
  name         String
  fatherName   String   @default("")
  isCompany    Boolean  @default(false)
  companyM2    Float    @default(0)
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shares       Share[]
  sectionOwners SectionOwner[]
  attorneyId   String?
  attorney     Attorney? @relation(fields: [attorneyId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Share {
  id        String @id @default(cuid())
  pay       Int
  payda     Int
  ownerId   String
  owner     Owner  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Attorney {
  id         String  @id @default(cuid())
  name       String
  notaryInfo String  @default("")
  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owners     Owner[]
  createdAt  DateTime @default(now())
}

model Section {
  id              String  @id @default(cuid())
  order           Int     @default(0)
  blokNo          String  @default("")
  katNo           String  @default("")
  bagimsizBolumNo String  @default("")
  nitelik         String  @default("")
  brutM2          Float   @default(0)
  netM2           Float   @default(0)
  arsaPayi        String  @default("")
  arsaPayiPayda   String  @default("")
  projectId       String
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sectionOwners   SectionOwner[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SectionOwner {
  id        String  @id @default(cuid())
  sectionId String
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     Owner   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([sectionId, ownerId])
}
